/*
 * -----------------------------------------------------------
 *  Config file for execution on HPC
 * -----------------------------------------------------------
 * Specification for a larger resource amount (e.g., CPU number) for each process
 *
 */

// HPC-specific params
executor {
    name            = 'slurm'
    queueSize       = 200
    submitRateLimit = '5 sec'
    pollInterval    = '1sec'
    retry.delay     = '1sec'
}

params {
    max_memory = "200.GB"
    max_time   = "192.h"
}

env {
    OPENBLAS_NUM_THREADS=1
    OMP_NUM_THREADS=1
}

// Process configuration
process {

    // Cluster-specific options (e.g., partition name, billing account, etc.)
    clusterOptions = '-p amd'

    // Error strategy
    errorStrategy = { task.exitStatus in [1,104,125,130,134,135,137,139,140,143,255] ? 'retry' : 'finish' }
    maxRetries    = 3
    maxErrors     = '-1'

    // Default resources
    cpus   = { check_max( 1    * task.attempt, 'cpus'   ) }
    memory = { scale_retry_memory( 2.GB, task.attempt ) }
    time   = { check_max( 3.h  * task.attempt, 'time'   ) }

    ////////// Step-1 processes

    // Converting BAM to FASTQ
    withName: 'S1:bam2fastq' {
        cpus   = 12
        memory = 2.GB
        time   = { check_max( 4.h  * task.attempt, 'time' ) }
    }

    // Primer disambiguation
    withName: 'S1:disambiguate' {
        cpus   = 1
        memory = 1.GB
        time   = 20.m
    }

    // Validate tags for demultiplexing
    withName: 'S1:tag_validation' {
        cpus   = 1
        memory = 1.GB
        time   = 20.m
    }

    // QC - PacBio single-end reads
    // vsearch currently does not suppot multithreading for `--fastq_filter`
    // see https://github.com/torognes/vsearch/issues/466
    withName: 'S1:qc_se' {
        cpus   = 2              // for pipes
        memory = 1.GB
        time   = { check_max( 2.h  * task.attempt, 'time' ) }
    }

    // QC - Illumina paired-end reads
    withName: 'S1:qc_pe' {
        // max threads for fastp = 16
        cpus   = 12
        memory = 20.GB
        time   = 4.h
    }

    // Demultiplexing of PacBio reads (with LIMA)
    withName: 'S1:demux' {
        cpus   = 12
        memory = { scale_retry_memory( 3.GB, task.attempt ) }
        time   = { check_max( 1.h  * task.attempt, 'time'   ) }
    }

    // Demultiplexing single-end reads (with cutadapt)
    withName: 'S1:demux_se' {
        cpus   = 16
        memory = 20.GB
        time   = 4.h
    }

    // Demultiplexing (non-merged) pair-end reads
    withName: 'S1:demux_pe' {
        cpus   = 10
        memory = 20.GB
        time   = 4.h
    }

    // Merging of Illumina PE reads
    withName: 'S1:merge_pe' {
        cpus   = 8
        memory = 20.GB
        time   = 4.h
    }

    // Check primers
    withName: 'S1:primer_check' {
        cpus   = 1
        memory = 1.GB
        time   = { check_max( 30.m * task.attempt, 'time'   ) }
    }

    // ITSx
    withName: 'S1:itsx' {
        cpus   = 20
        memory = { scale_retry_memory( 10.GB, task.attempt ) }
        time   = { check_max( 20.h  * task.attempt, 'time'   ) }
    }

    // Collect all ITS parts extracted by ITSx
    withName: 'S1:itsx_collect' {
        cpus   = 1
        memory = 1.GB
        time   = { check_max( 30.m  * task.attempt, 'time'   ) }
    }

    // Sequence quality tables
    withName: 'S1:seq_qual' {
        cpus   = 6
        memory = { scale_retry_memory( 50.GB, task.attempt ) }
        time   = { check_max( 1.h   * task.attempt, 'time'   ) }
    }

    // Homopolymer compression
    withName: 'S1:homopolymer' {
        cpus = 2
        memory = 2.GB
        time   = { check_max( 3.h  * task.attempt, 'time'   ) }
    }

    // Reference-based chimera removal
    withName: 'S1:CHIMERA_REMOVAL:chimera_ref' {
        cpus = 4
        memory = { scale_retry_memory( 3.GB, task.attempt ) }
        time   = { check_max( 1.h  * task.attempt, 'time'   ) }
    }

    // Chimera rescue
    withName: 'S1:CHIMERA_REMOVAL:chimera_rescue' {
        cpus   = 1
        memory = { scale_retry_memory( 1.GB, task.attempt ) }
        time   = { check_max( 1.h  * task.attempt, 'time'   ) }
    }

    // De novo chimera search
    withName: 'S1:CHIMERA_REMOVAL:chimera_denovo' {
        cpus   = 1
        memory = { scale_retry_memory( 1.GB, task.attempt ) }
        time   = { check_max( 1.h  * task.attempt, 'time'   ) }
    }

    // Aggregate de novo chimeras
    withName: 'S1:CHIMERA_REMOVAL:chimera_denovo_agg' {
        cpus   = 1
        memory = 1.GB
        time   = { check_max( 1.h  * task.attempt, 'time'   ) }
    }

    // Pool sequences (for tag-jump removal and final sequence table creation)
    withName: 'S1:pool_seqs' {
        cpus   = 3
        memory = { scale_retry_memory( 1.GB, task.attempt ) }
        time   = { check_max( 30.m * task.attempt, 'time'   ) }
    }

    // Dereplication or pre-clustering prior to tag-jump removal
    withName: 'S1:tj_preclust' {
        cpus   = 12
        memory = { scale_retry_memory( 12.GB, task.attempt ) }
        time   = { check_max( 4.h   * task.attempt, 'time'   ) }
    }

    // Tag-jump removal
    withName: 'S1:tj' {
        cpus   = 1
        memory = { scale_retry_memory( 2.GB, task.attempt ) }
        time   = { check_max( 30.m  * task.attempt, 'time'   ) }
    }

    // Create sequence table
    withName: 'S1:prep_seqtab' {
        cpus   = 8
        memory = { scale_retry_memory( 50.GB, task.attempt ) }
        time   = { check_max( 30.m  * task.attempt, 'time'   ) }
    }

    // Read count summary
    withName: 'S1:read_counts' {
        cpus = 4
        memory = { scale_retry_memory( 1.GB, task.attempt ) }
        time   = { check_max( 30.m * task.attempt, 'time'   ) }
    }


    ////////// Step-2 processes

    // Aggregate sequences, remove de novo chimeras
    withName: 'S2:aggregate_sequences' {
        cpus = 20
        memory = { scale_retry_memory( 80.GB, task.attempt ) }
        time   = { check_max( 2.h   * task.attempt, 'time'   ) }
    }

    // Dereplication (only comression is multithreaded)
    withName: 'S2:dereplication' {
        cpus   = 20
        memory = { scale_retry_memory( 4.GB, task.attempt ) }
        time   = { check_max( 5.h * task.attempt, 'time'   ) }
    }
    
    // 100% clustering with sequence length variation allowed (UNITE-style)
    withName: 'S2:dereplication_unite' {
        cpus   = 20
        memory = { scale_retry_memory( 50.GB, task.attempt ) }
        time   = { check_max( 24.h  * task.attempt, 'time'   ) }
    }

    // Pre-clustering
    withName: 'S2:linclust' {
        cpus = 20
        memory = { scale_retry_memory( 120.GB, task.attempt ) }
        time   = { check_max( 12.h   * task.attempt, 'time'   ) }
    }

    // Bucketize sequences into clusters
    withName: 'S2:bucketize' {
        cpus = 10
        memory = { scale_retry_memory( 50.GB, task.attempt ) }
        time   = { check_max( 3.h   * task.attempt, 'time'   ) }
    }

    // UNOISE
    withName: 'S2:CLUSTERING:unoise' {
        cpus   = 30
        memory = { scale_retry_memory( 40.GB, task.attempt ) }
        time   = { check_max( 30.h  * task.attempt, 'time'   ) }
    }

    // DADA2 - Prepare sequence subset for error estimation (shared across buckets)
    withName: 'S2:prepare_dada2_error_subset'{
        cpus = 20
        memory = { scale_retry_memory( 8.GB, task.attempt ) }
        time   = { check_max( 1.h   * task.attempt, 'time'   ) }
    }

    // DADA2 - Estimate error rates (shared across buckets, outside of the clustering subworkflow)
    withName: 'S2:dada2_error_est' {
        cpus = 20
        memory = { scale_retry_memory( 60.GB, task.attempt ) }
        time   = { check_max( 30.h  * task.attempt, 'time'   ) }
    }

    // DADA2 - Estimate error rates
    withName: 'S2:CLUSTERING:dada2_error_est' {
        cpus = 20
        memory = { scale_retry_memory( 60.GB, task.attempt ) }
        time   = { check_max( 30.h  * task.attempt, 'time'   ) }
    }

    // DADA2 - Denoise sequences
    withName: 'S2:CLUSTERING:dada2_inference' {
        cpus = 20
        memory = { scale_retry_memory( 60.GB, task.attempt ) }
        time   = { check_max( 30.h  * task.attempt, 'time'   ) }
    }

    // PAPA2 - Estimate error rates (shared across buckets, outside of the clustering subworkflow)
    withName: 'S2:papa2_error_est' {
        cpus = 20
        memory = { scale_retry_memory( 10.GB, task.attempt ) }
        time   = { check_max( 5.h   * task.attempt, 'time'   ) }
    }

    // PAPA2 - Estimate error rates
    withName: 'S2:CLUSTERING:papa2_error_est' {
        cpus = 20
        memory = { scale_retry_memory( 10.GB, task.attempt ) }
        time   = { check_max( 5.h   * task.attempt, 'time'   ) }
    }

    // PAPA2 - Denoise sequences
    withName: 'S2:CLUSTERING:papa2_inference' {
        cpus = 20
        memory = { scale_retry_memory( 10.GB, task.attempt ) }
        time   = { check_max( 20.h  * task.attempt, 'time'   ) }
    }

    // VSEARCH clustering
    withName: 'S2:CLUSTERING:cluster_vsearch' {
        cpus   = 30
        memory = { scale_retry_memory( 80.GB, task.attempt ) }
        time   = { check_max( 30.h  * task.attempt, 'time'   ) }
    }

    // SWARM clustering
    withName: 'S2:CLUSTERING:cluster_swarm' {
        cpus   = 30
        memory = { scale_retry_memory( 80.GB, task.attempt ) }
        time   = { check_max( 24.h  * task.attempt, 'time'   ) }
    }

    // Bucketizing workflow - merge chunks into a single file
    withName: 'S2:merge_buckets' {
        cpus   = 4
        memory = { scale_retry_memory( 40.GB, task.attempt ) }
        time   = { check_max( 4.h   * task.attempt, 'time'   ) }
    }

    // Merge UC files
    withName: 'S2:merge_uc' {
        cpus   = 4
        memory = { scale_retry_memory( 40.GB, task.attempt ) }
        time   = { check_max( 4.h   * task.attempt, 'time'   ) }
    }

    // Summarize sequence abundance by OTU
    withName: 'S2:summarize' {
        cpus   = 12
        memory = { scale_retry_memory( 60.GB, task.attempt ) }
        time   = { check_max( 5.h   * task.attempt, 'time'   ) }
    }

    // Post-clustering curation with LULU
    withName: 'S2:lulu' {
        cpus   = 30
        memory = { scale_retry_memory( 60.GB, task.attempt ) }
        time   = { check_max( 24.h  * task.attempt, 'time'   ) }
    }

}

// Function to scale memory requirements based on the number of retries
//   First attempt = 1x
//   2nd attempt   = 1.25x
//   3rd attempt   = 1.5x
//   4th attempt   = 1.75x
//   Max cap       = 3.0x
//   Global cap    = params.max_memory
def scale_retry_memory(base, attempt) {
    def retries = Math.max(attempt as int, 1) - 1
    def factor = Math.min(1.0 + (retries * 0.25), 3.0)
    def scaledBytes = (base.toBytes() * factor) as long
    return check_max(scaledBytes.B, 'memory')
}


// Function to ensure that resource requirements don't go beyond a maximum limit
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}
